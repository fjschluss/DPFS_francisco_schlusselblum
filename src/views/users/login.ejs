<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head') %>

<body>
    
    <!-- HEADER -->
    <%- include('../partials/header') %>

    <!-- MAIN -->
    <main class="auth-page">
 
        <div class="auth-visual">
                <div class="auth-visual-quote">
                <div class="quote-mark">"</div>
                <blockquote>El diseño no es solo cómo se ve, es cómo funciona para quien lo usa.</blockquote>
                <p class="quote-author">— Ludmila Borrelli, fundadora de LuBo</p>
            </div>
        </div>
    
        <div class="auth-form-panel">
            <div class="auth-form-inner">
        
                <h1 class="auth-title">Bienvenida/o de vuelta</h1>
                <p class="auth-subtitle">¿No tenés cuenta? <a href="/users/register">Registrate acá</a></p>
        
                <div class="login-error-banner">
                    <span>⚠</span>
                    <span>El correo o la contraseña son incorrectos. Revisá tus datos e intentá de nuevo.</span>
                </div>
        
                <form action="#" method="post" novalidate>
        
                <div class="form-group">
                    <label class="form-label" for="email">Correo electrónico</label>
                    <input class="form-input has-error" type="email" id="email" name="email" placeholder="tu@email.com" value="usuarioerrror@mail.com" />
                    <p class="error-msg">⚠ Este correo no está registrado</p>
                </div>
        
                <div class="form-group">
                    <label class="form-label" for="password">Contraseña</label>
                    <div class="password-wrapper">
                        <input class="form-input" type="password" id="password" name="password" placeholder="Tu contraseña" />
                        <button type="button" class="btn-eye" aria-label="Mostrar contraseña">👁</button>
                    </div>
                </div>
        
                <div class="remember-row">
                    <label class="remember-check">
                    <input type="checkbox" name="remember" />
                    Recordarme
                    </label>
                    <a href="#" class="forgot-link">¿Olvidaste tu contraseña?</a>
                </div>
        
                <button type="submit" class="btn btn-primary btn-full btn-lg">Ingresar</button>
        
                <div class="divider-row">o ingresá con</div>
        
                <button type="button" class="btn btn-outline btn-full">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                    Continuar con Google
                </button>
        
                </form>
        
            </div>
        </div>
    
    </main>

    <!-- FOOTER -->
    <%- include('../partials/footer') %>


</body>
</html>