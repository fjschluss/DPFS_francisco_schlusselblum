<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tech Pack Básico — LuBo</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    
    <!-- HEADER -->
    <header class="site-header">
        <nav class="container nav-inner">
            <a href="/" class="logo">
                <img src="/images/logo.svg" alt="LuBo - Ludmila Borrelli">
            </a>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/products">Productos</a></li>
                <li><a href="#about">Nosotros</a></li>
            </ul>
            <button class="btn-hamburger" onclick="this.closest('nav').querySelector('.nav-links').classList.toggle('open')">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="nav-actions">
                <a href="/users/login" class="btn btn-outline btn-sm">Ingresar</a>
                <a href="/cart" class="btn-icon" title="Carrito">
                    <img src="/images/carrito.svg" alt="Carrito">
                </a>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="breadcrumb">
            <a href="/">Inicio</a>
            <span class="breadcrumb-sep">›</span>
            <a href="/products">Productos</a>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-current">Tech Pack Básico — Remeras</span>
        </div>
    </div>

    <!-- MAIN -->
    <main>
        <div class="container">
            <div class="product-detail">
        
                <div class="gallery">
                    <div class="gallery-main">
                        <img src="https://placehold.co/600x450/E8DDD4/8C8480?text=Tech+Pack+Preview" alt="Vista previa del Tech Pack" />
                    </div>
                    <div class="gallery-thumbs">
                        <div class="thumb active">
                            <img src="https://placehold.co/72x72/E8DDD4/8C8480?text=1" alt="Vista 1" />
                        </div>
                        <div class="thumb">
                            <img src="https://placehold.co/72x72/DDD5CC/8C8480?text=2" alt="Vista 2" />
                        </div>
                        <div class="thumb">
                            <img src="https://placehold.co/72x72/ECDFD5/8C8480?text=3" alt="Vista 3" />
                        </div>
                    </div>
                </div>
        
                <div class="product-info">
                    <p class="product-category">Tech Pack</p>
                    <h1>Tech Pack Básico — Remeras</h1>
        
                    <div class="rating-row">
                        <span class="stars">★★★★★</span>
                        <span>4.9</span>
                        <span>·</span>
                        <span>38 ventas</span>
                    </div>
            
                    <div class="price-block">
                        <span class="price-main">$1.200</span>
                        <span class="price-old">$1.800</span>
                        <span class="badge">-33%</span>
                    </div>
            
                    <p class="description">
                        Ficha técnica completa para remeras básicas, diseñada para profesionalizar el proceso de producción de tu marca o emprendimiento. Incluye todos los campos necesarios para comunicarle a tu taller exactamente lo que necesitás, sin errores ni idas y vueltas.
                    </p>
            
                    <div class="includes-list">
                        <h4>Incluye</h4>
                        <ul>
                            <li>Archivo editable en formato .xlsx y .pdf</li>
                            <li>Diseño técnico (flat) frente y espalda</li>
                            <li>Tabla de medidas talle S a XXL</li>
                            <li>Sección de materiales y avíos</li>
                            <li>Instrucciones de lavado y etiquetado</li>
                            <li>Guía de uso en PDF (2 páginas)</li>
                        </ul>
                    </div>
            
                    <div class="add-to-cart-section">
                        <a href="/cart" class="btn btn-accent btn-cart">Agregar al carrito</a>
                        <button class="btn btn-outline">♡ Guardar</button>
                    </div>
            
                    <div class="product-meta">
                        <div class="meta-row">
                            <span class="meta-label">Formato</span>
                            <span class="meta-value">.xlsx + .pdf editable</span>
                        </div>
                        <div class="meta-row">
                            <span class="meta-label">Entrega</span>
                            <span class="meta-value">Descarga inmediata</span>
                        </div>
                        <div class="meta-row">
                            <span class="meta-label">Licencia</span>
                            <span class="meta-value">Uso personal y comercial (1 marca)</span>
                        </div>
                        <div class="meta-row">
                            <span class="meta-label">Categoría</span>
                            <span class="meta-value">Tech Pack · Remeras</span>
                        </div>
                    </div>
                </div>
        
            </div>
        </div>
    
        <section class="related-section">
        <div class="container">
            <div class="section-header">
                <span class="eyebrow">También puede interesarte</span>
                <h2>Productos relacionados</h2>
            </div>
            <div class="product-grid">
                <article class="product-card">
                    <a href="/products/:id">
                        <div class="product-card-img">
                            <img src="https://placehold.co/400x300/DDD5CC/8C8480?text=Flat+Pack" alt="Pack Flats Pantalones" />
                        </div>
                        <div class="product-card-body">
                            <p class="product-category">Diseños Técnicos</p>
                            <h3 class="product-name">Pack Flats — Pantalones</h3>
                            <p class="product-price">$2.800</p>
                        </div>
                    </a>
                </article>
                <article class="product-card">
                    <a href="/products">
                        <div class="product-card-img">
                            <img src="https://placehold.co/400x300/ECDFD5/8C8480?text=Moldes" alt="Moldes Base" />
                        </div>
                        <div class="product-card-body">
                            <p class="product-category">Moldes</p>
                            <h3 class="product-name">Kit Moldes Base — S a XL</h3>
                            <p class="product-price">$3.500</p>
                        </div>
                    </a>
                </article>
                <article class="product-card">
                    <a href="/products">
                        <div class="product-card-img">
                            <img src="https://placehold.co/400x300/E0D7CE/8C8480?text=Tech+Pack+Pro" alt="Tech Pack Pro" />
                        </div>
                        <div class="product-card-body">
                            <p class="product-category">Tech Pack</p>
                            <h3 class="product-name">Tech Pack Pro — Outerwear</h3>
                            <p class="product-price">$2.200</p>
                        </div>
                    </a>
                </article>
            </div>
        </div>
        </section>
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <a href="/">
                            <img src="/images/logo.svg" alt="LuBo - Ludmila Borrelli">
                        </a>
                    </div>
                    <p class="footer-desc">Marketplace de recursos digitales para diseñadores de indumentaria, creado por Ludmila Borrelli.</p>
                </div>
                <div>
                    <p class="footer-col-title">Sitio</p>
                    <ul class="footer-links">
                        <li><a href="/">Inicio</a></li>
                        <li><a href="/products">Productos</a></li>
                        <li><a href="#about">Cómo funciona</a></li>
                    </ul>
                </div>
                <div>
                    <p class="footer-col-title">Cuenta</p>
                    <ul class="footer-links">
                        <li><a href="/users/register">Registrarme</a></li>
                        <li><a href="/users/login">Ingresar</a></li>
                        <li><a href="/cart">Mi carrito</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>© 2026 LuBo — Ludmila Borrelli. Todos los derechos reservados.</span>
                <span>Diseño por Francisco Schlusselblum · Digital House DPFS</span>
            </div>
        </div>
    </footer>

</body>
</html>