<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>

    <div class="container">
        <nav class="breadcrumb">
            <a href="/">Inicio</a>
            <span class="breadcrumb-sep">›</span>
            <a href="/products">Productos</a>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-current"><%= product.name %></span>
        </nav>
    </div>

    <main>
        <div class="container">
            <div class="product-detail">

                <div class="gallery">
                    <div class="gallery-main">
                        <img src="<%= product.image %>"
                             alt="<%= product.name %>"
                             onerror="this.src='https://placehold.co/600x450/D6CFC6/8C8480?text=LuBo'">
                    </div>
                </div>

                <div class="product-info">
                    <p class="product-category"><%= product.category %></p>
                    <h1><%= product.name %></h1>

                    <div class="price-block">
                        <span class="price-main">$<%= product.price.toLocaleString('es-AR') %></span>
                    </div>

                    <p class="description"><%= product.description %></p>

                    <% if (product.colors && product.colors[0] !== 'N/A') { %>
                        <div class="includes-list" style="margin-bottom:2rem;">
                            <h4>Colores disponibles</h4>
                            <ul>
                                <% product.colors.forEach(color => { %>
                                    <li><%= color %></li>
                                <% }) %>
                            </ul>
                        </div>
                    <% } %>

                    <div class="add-to-cart-section">
                        <button class="btn btn-accent btn-cart">Agregar al carrito</button>
                        <a href="/products/<%= product.id %>/edit" class="btn btn-outline">Editar producto</a>
                    </div>

                    <div class="product-meta">
                        <div class="meta-row">
                            <span class="meta-label">Entrega</span>
                            <span class="meta-value">Descarga instantánea</span>
                        </div>
                        <div class="meta-row">
                            <span class="meta-label">Licencia</span>
                            <span class="meta-value">Uso personal y comercial</span>
                        </div>
                        <div class="meta-row">
                            <span class="meta-label">Categoría</span>
                            <span class="meta-value"><%= product.category %></span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>