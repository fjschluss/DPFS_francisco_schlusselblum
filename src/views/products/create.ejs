<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>

    <main class="section-sm">
        <div class="container" style="max-width:680px;">

            <span class="eyebrow">Admin</span>
            <h1 style="margin-bottom:0.5rem;">Nuevo Producto</h1>
            <p style="color:var(--warm-gray); margin-bottom:2.5rem;">
                Completá el formulario para agregar un recurso al catálogo.
            </p>

            <form action="/products/create" method="POST">

                <div class="form-group">
                    <label class="form-label" for="name">Nombre del producto *</label>
                    <input class="form-input" type="text" id="name" name="name" required
                           placeholder="Ej: Tech Pack Básico — Remeras">
                </div>

                <div class="form-group">
                    <label class="form-label" for="description">Descripción *</label>
                    <textarea class="form-input" id="description" name="description"
                              rows="4" required
                              placeholder="Describí qué incluye el recurso..."></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="category">Categoría *</label>
                        <select class="form-input" id="category" name="category" required>
                            <option value="" disabled selected>Seleccionar...</option>
                            <option value="Fichas Técnicas">Fichas Técnicas</option>
                            <option value="Diseños Técnicos">Diseños Técnicos</option>
                            <option value="Moldes y Patrones">Moldes y Patrones</option>
                            <option value="Recursos Digitales">Recursos Digitales</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="price">Precio (ARS) *</label>
                        <input class="form-input" type="number" id="price" name="price"
                               required min="0" step="100" placeholder="Ej: 3500">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="image">URL de imagen</label>
                    <input class="form-input" type="text" id="image" name="image"
                           placeholder="/images/mi-producto.jpg">
                    <span class="form-hint">Ruta relativa dentro de /public/images/</span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="colors">Colores / Talles</label>
                    <input class="form-input" type="text" id="colors" name="colors"
                           placeholder="Ej: Negro, Blanco, Gris">
                    <span class="form-hint">Separados por coma. Escribí N/A si no aplica.</span>
                </div>

                <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:2rem;">
                    <a href="/products" class="btn btn-outline">Cancelar</a>
                    <button type="submit" class="btn btn-accent">Crear producto</button>
                </div>

            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>