<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>

    <main class="page-content">
        <div class="container container--narrow">
            <div class="page-header">
                <h1>Nuevo Producto</h1>
                <p>Completá el formulario para agregar un nuevo recurso al catálogo.</p>
            </div>

            <form action="/products/create" method="POST" class="form-card">
                <div class="form-group">
                    <label for="name">Nombre del producto *</label>
                    <input type="text" id="name" name="name" required
                           placeholder="Ej: Tech Pack Básico – Remera">
                </div>

                <div class="form-group">
                    <label for="description">Descripción *</label>
                    <textarea id="description" name="description" rows="4" required
                              placeholder="Describí el producto, qué incluye, para qué sirve..."></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="category">Categoría *</label>
                        <select id="category" name="category" required>
                            <option value="" disabled selected>Seleccionar...</option>
                            <option value="Fichas Técnicas">Fichas Técnicas</option>
                            <option value="Diseños Técnicos">Diseños Técnicos</option>
                            <option value="Moldes y Patrones">Moldes y Patrones</option>
                            <option value="Recursos Digitales">Recursos Digitales</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="price">Precio (ARS) *</label>
                        <input type="number" id="price" name="price" required min="0" step="100"
                               placeholder="Ej: 3500">
                    </div>
                </div>

                <div class="form-group">
                    <label for="image">URL de imagen</label>
                    <input type="text" id="image" name="image"
                           placeholder="/images/mi-producto.jpg">
                    <span class="form-hint">Subí la imagen a la carpeta /public/images y pegá la ruta aquí.</span>
                </div>

                <div class="form-group">
                    <label for="colors">Colores / Talles disponibles</label>
                    <input type="text" id="colors" name="colors"
                           placeholder="Ej: Negro, Blanco, Gris (separados por comas)">
                    <span class="form-hint">Escribí N/A si no aplica.</span>
                </div>

                <div class="form-actions">
                    <a href="/products" class="btn-ghost">Cancelar</a>
                    <button type="submit" class="btn-primary">Crear producto</button>
                </div>
            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>