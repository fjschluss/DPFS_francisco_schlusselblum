<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>

    <main class="page-content">
        <div class="container container--narrow">
            <div class="page-header">
                <h1>Editar Producto</h1>
                <p>Modificá los datos del producto. Los campos con * son obligatorios.</p>
            </div>

            <form action="/products/<%= product.id %>/edit" method="POST" class="form-card">
                <div class="form-group">
                    <label for="name">Nombre del producto *</label>
                    <input type="text" id="name" name="name" required value="<%= product.name %>">
                </div>

                <div class="form-group">
                    <label for="description">Descripción *</label>
                    <textarea id="description" name="description" rows="4" required><%= product.description %></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="category">Categoría *</label>
                        <select id="category" name="category" required>
                            <option value="Fichas Técnicas" <%= product.category === 'Fichas Técnicas' ? 'selected' : '' %>>Fichas Técnicas</option>
                            <option value="Diseños Técnicos" <%= product.category === 'Diseños Técnicos' ? 'selected' : '' %>>Diseños Técnicos</option>
                            <option value="Moldes y Patrones" <%= product.category === 'Moldes y Patrones' ? 'selected' : '' %>>Moldes y Patrones</option>
                            <option value="Recursos Digitales" <%= product.category === 'Recursos Digitales' ? 'selected' : '' %>>Recursos Digitales</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="price">Precio (ARS) *</label>
                        <input type="number" id="price" name="price" required min="0" step="100"
                               value="<%= product.price %>">
                    </div>
                </div>

                <div class="form-group">
                    <label for="image">URL de imagen</label>
                    <input type="text" id="image" name="image" value="<%= product.image %>">
                </div>

                <div class="form-group">
                    <label for="colors">Colores / Talles disponibles</label>
                    <input type="text" id="colors" name="colors"
                           value="<%= product.colors.join(', ') %>">
                    <span class="form-hint">Separados por coma. Ej: Negro, Blanco, Gris</span>
                </div>

                <div class="form-actions">
                    <a href="/products/<%= product.id %>" class="btn-ghost">Cancelar</a>
                    <button type="submit" class="btn-primary">Guardar cambios</button>
                </div>
            </form>

            <div class="danger-zone">
                <h4>Vista previa del producto</h4>
                <a href="/products/<%= product.id %>" class="btn-text">Ver página del producto →</a>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
