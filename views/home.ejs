<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuBo</title>
    <link rel="stylesheet" href="/stylesheets/main.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar container">
            
            <div class="logo">
                <a href="home.html">
                    <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
                </a>
            </div>

            <ul class="menu">
                <li><a href="home.html">Inicio</a></li>
                <li><a href="#">Comprar</a></li>
                <li><a href="#">Sobre Mi</a></li>
            </ul>

            <div class="nav-actions">
                <a href="login.html">Login</a>
                <a href="register.html">Registrarse</a>
                <a href="cart.html" class="cart-icon">
                    <img src="/images/Carrito.png" alt="Carrito">
                </a>
            </div>

        </nav>
    </header>

    <!-- MAIN -->
    <main class="container">

        <!-- HERO -->
        <section class="hero">
            <h1>Recursos digitales para diseño de indumentaria</h1>
            <p>Fichas técnicas, moldes y herramientas profesionales listas para usar.</p>
            <a href="#productos" class="btn-primary">Explorar productos</a>
        </section>

        <!-- PRODUCTOS -->
        <section id="productos" class="products">

            <div class="card">
                <h3>Tech Pack Camisa Oversize</h3>
                <p class="price">$20 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Molde Pantalón Sastrero</h3>
                <p class="price">$25 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Ficha Técnica Vestido Midi</h3>
                <p class="price">$18 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Molde Blazer Clásico</h3>
                <p class="price">$30 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Pack Básicos Mujer</h3>
                <p class="price">$45 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Plantilla Excel Producción</h3>
                <p class="price">$15 USD</p>
                <a href="productDetail.html" class="btn-secondary">Ver detalle</a>
            </div>

        </section>

    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container footer-content">

            <div class="footer-brand">
                <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
            </div>

            <div class="footer-links">
                <a href="#">Política de privacidad</a>
                <a href="#">Términos y condiciones</a>
                <a href="#">Contacto</a>
            </div>

            <div class="footer-copy">
                <p>© 2026 LuBo — Ludmila Borrelli</p>
            </div>

        </div>
    </footer>

</body>
</html>