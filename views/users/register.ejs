<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Registro" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container auth-page">
            <h1>Registro</h1>

            <form action="/users/register" method="POST" enctype="multipart/form-data">
                <input type="text" name="firstName" value="<%= oldData.firstName ? oldData.firstName : '' %>" placeholder="Nombre">
                <% if (errors.firstName) { %>
                    <p class="error"><%= errors.firstName.msg %></p>
                <% } %>

                <input type="text" name="lastName" value="<%= oldData.lastName ? oldData.lastName : '' %>" placeholder="Apellido">

                <input type="email" name="email" value="<%= oldData.email ? oldData.email : '' %>" placeholder="Email">
                <% if (errors.email) { %>
                    <p class="error"><%= errors.email.msg %></p>
                <% } %>

                <input type="password" name="password" placeholder="Contraseña">
                <% if (errors.password) { %>
                    <p class="error"><%= errors.password.msg %></p>
                <% } %>

                <input type="file" name="image">

                <button type="submit">Registrarse</button>
            </form>

            <a href="/users/login">¿Ya tenés cuenta? Iniciá sesión</a>
        </main>

        <%- include("../partials/footer") %>

    </body>
</html>