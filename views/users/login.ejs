<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Login" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container auth-page">
            <h1>Iniciar sesión</h1>

            <form action="/users/login" method="POST">
                <input type="email" name="email" value="<%= oldData.email ? oldData.email : '' %>" placeholder="Email">
                <% if (errors.email) { %>
                    <p class="error"><%= errors.email.msg %></p>
                <% } %>

                <input type="password" name="password" placeholder="Contraseña">
                <% if (errors.password) { %>
                    <p class="error"><%= errors.password.msg %></p>
                <% } %>

                <label>
                    <input type="checkbox" name="remember"> Recordarme
                </label>

                <button type="submit">Ingresar</button>
            </form>

            <a href="/users/register">¿No tenés cuenta? Registrate</a>
        </main>

        <%- include("../partials/footer") %>

    </body>
</html>