<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuBo</title>
    <link rel="stylesheet" href="/stylesheets/main.css">
</head>

<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar container">

            <div class="logo">
                <a href="/">
                    <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
                </a>
            </div>

            <ul class="menu">
                <li><a href="/">Inicio</a></li>
                <li><a href="#">Comprar</a></li>
                <li><a href="#">Sobre Mi</a></li>
            </ul>

            <div class="nav-actions">
                <a href="/users/login">Login</a>
                <a href="/users/register">Registrarse</a>
                <a href="/cart" class="cart-icon">
                    <img src="/images/Carrito.png" alt="Carrito">
                </a>
            </div>
                
        </nav>
    </header>

    <!-- MAIN -->
    <main class="container cart-page">

        <h1 class="cart-title">Carrito de compras</h1>

        <div class="cart-layout">

            <!-- Lista de productos -->
            <div class="cart-items">

                <div class="cart-item">
                    <div class="item-info">
                        <h3>Tech Pack Camisa Oversize</h3>
                        <p>$20 USD</p>
                    </div>

                    <div class="item-actions">
                        <span>Cantidad: 1</span>
                        <button class="btn-secondary">Eliminar</button>
                    </div>
                </div>

                <div class="cart-item">
                    <div class="item-info">
                        <h3>Molde Pantalón Sastrero</h3>
                        <p>$25 USD</p>
                    </div>

                    <div class="item-actions">
                        <span>Cantidad: 1</span>
                        <button class="btn-secondary">Eliminar</button>
                    </div>
                </div>

            </div>

            <!-- Resumen -->
            <div class="cart-summary">

                <h2>Resumen</h2>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>$45 USD</span>
                </div>

                <div class="summary-row total">
                    <span>Total</span>
                    <span>$45 USD</span>
                </div>

                <button class="btn-primary">Finalizar compra</button>

                <a href="/" class="continue-shopping">
                    Seguir comprando
                </a>

            </div>

        </div>

    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container footer-content">

            <div class="footer-brand">
                <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
            </div>

            <div class="footer-links">
                <a href="#">Política de Privacidad</a>
                <a href="#">Términos y Condiciones</a>
                <a href="#">Contacto</a>
            </div>

            <div class="footer-copy">
                <p>© 2026 LuBo — Ludmila Borrelli</p>
            </div>
        </div>
    </footer>

</body>
</html>