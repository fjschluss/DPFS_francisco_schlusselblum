<!DOCTYPE html>
<html lang="en">

<%- include("partials/head", { title: "Carrito" }) %>

<body>

    <!-- HEADER -->
    <%- include("partials/header") %>

    <!-- MAIN -->
    <main class="container cart-page">

        <h1 class="cart-title">Carrito de compras</h1>

        <div class="cart-layout">

            <!-- Lista de productos -->
            <div class="cart-items">

                <div class="cart-item">
                    <div class="item-info">
                        <h3>Tech Pack Camisa Oversize</h3>
                        <p>$20 USD</p>
                    </div>

                    <div class="item-actions">
                        <span>Cantidad: 1</span>
                        <button class="btn-secondary">Eliminar</button>
                    </div>
                </div>

                <div class="cart-item">
                    <div class="item-info">
                        <h3>Molde Pantalón Sastrero</h3>
                        <p>$25 USD</p>
                    </div>

                    <div class="item-actions">
                        <span>Cantidad: 1</span>
                        <button class="btn-secondary">Eliminar</button>
                    </div>
                </div>

            </div>

            <!-- Resumen -->
            <div class="cart-summary">

                <h2>Resumen</h2>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>$45 USD</span>
                </div>

                <div class="summary-row total">
                    <span>Total</span>
                    <span>$45 USD</span>
                </div>

                <button class="btn-primary">Finalizar compra</button>

                <a href="/" class="continue-shopping">
                    Seguir comprando
                </a>

            </div>

        </div>

    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>

</body>
</html>