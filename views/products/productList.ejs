<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Productos" }) %>

    <body>

        <%- include("../partials/header") %>

        <main>
            
            <h1>Listado de Productos</h1>

            <a href="/products/create">
                Crear nuevo producto
            </a>

            <hr>

            <div class="products-container">

                <% productos.forEach(producto => { %>

                    <div class="product-card">

                        <img src="/images/<%= producto.imagen %>" alt="<%= producto.nombre %>">

                        <h3><%= producto.nombre %></h3>

                        <p>$ <%= producto.precio %></p>

                        <p>Categoría: <%= producto.categoria ? producto.categoria.nombre : "Sin categoría" %></p>

                        <p>Marca: <%= producto.brand ? producto.brand.nombre : "Sin marca" %></p>

                        <a href="/products/<%= producto.id_productos %>">Ver detalle</a>

                        <a href="/products/<%= producto.id_productos %>/edit">Editar</a>

                        <form action="/products/<%= producto.id_productos %>?_method=DELETE" method="POST" style="margin-top: 20px;">
                            <button type="submit" onclick="return confirm('¿Estás seguro que querés eliminar este producto?')">
                                Eliminar Producto
                            </button>
                        </form>

                    </div>

                <% }) %>

            </div>

        </main>

        <%- include("../partials/footer") %>

    </body>
</html>