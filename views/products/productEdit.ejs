<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Editar Producto" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container">

            <div class="edit">

                <h1>Editar Producto</h1>

                <form action="/products/<%= producto.id_productos %>?_method=PUT" method="POST">

                    <div class="form-group">
                        <label>Nombre:</label>
                        <input type="text" name="nombre" value="<%= producto.nombre %>" required>
                    </div>

                    <div class="form-group">
                        <label>Descripción:</label>
                        <textarea name="descripcion" required><%= producto.descripcion %></textarea>
                    </div>

                    <div class="form-group">
                        <label>Imagen:</label>
                        <input type="text" name="imagen" value="<%= producto.imagen %>">
                    </div>

                    <div class="form-row">

                        <div class="form-group">
                            <label>Categoría:</label>
                            <select name="categoria" required>
                                <% categorias.forEach(cat => { %>
                                    <option value="<%= cat.id_categorias %>" 
                                        <%= producto.id_categorias == cat.id_categorias ? 'selected' : '' %>>
                                        <%= cat.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Marca:</label>
                            <select name="brand" required>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand.id_brands %>" 
                                        <%= producto.id_brands == brand.id_brands ? 'selected' : '' %>>
                                        <%= brand.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Precio:</label>
                            <input type="number" name="precio" value="<%= producto.precio %>" required>
                        </div>

                    </div>

                    <div class="form-actions">
                        <button type="submit">Guardar Cambios</button>

                        <a href="/products/<%= producto.id_productos %>" class="cancel-btn">
                            Cancelar
                        </a>
                    </div>

                </form>

            </div>

        </main>

        <%- include("../partials/footer") %>

    </body>
</html>