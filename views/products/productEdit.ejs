<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Editar Producto" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container">
            <h1>Editar producto</h1>

            <form action="/products/<%= product.id %>" method="POST">

                <label for="name">Nombre del producto</label>
                <input type="text" id="name" name="name" value="<%= product.name %>" required>

                <label for="description">Descripción</label>
                <textarea id="description" name="description" required><%= product.description %></textarea>

                <label for="image">Imagen (URL)</label>
                <input type="text" id="image" name="image" value="<%= product.image %>">

                <label for="category">Categoría</label>
                <input type="text" id="category" name="category" value="<%= product.category %>">

                <label for="colors">Colores</label>
                <input type="text" id="colors" name="colors" value="<%= product.colors %>">

                <label for="price">Precio</label>
                <input type="number" id="price" name="price" step="0.01" value="<%= product.price %>" required>

                <button type="submit">Guardar cambios</button>

                <a href="/products" class="cancel-btn">
                    Cancelar
                </a>

            </form>
        </main>

        <%- include("../partials/footer") %>

    </body>
</html>