<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Crear Producto" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container">

            <h1>Crear Nuevo Producto</h1>

            <form action="/products" method="POST">

                <label>Nombre:</label>
                <input type="text" name="name" required>

                <label>Descripción:</label>
                <textarea name="description" required></textarea>

                <label>Imagen:</label>
                <input type="text" name="image" required>

                <label>Categoría:</label>
                <input type="text" name="category" required>

                <label>Colores (separados por coma):</label>
                <input type="text" name="colors" required>

                <label>Talles (separados por coma):</label>
                <input type="text" name="sizes" required>

                <label>Precio:</label>
                <input type="number" name="price" required>

                <button type="submit">Crear Producto</button>

                <a href="/products" class="cancel-btn">
                    Cancelar
                </a>

            </form>

        </main>

        <%- include("../partials/footer") %>

    </body>
</html>