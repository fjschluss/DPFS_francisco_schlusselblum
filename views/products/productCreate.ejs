<!DOCTYPE html>
<html lang="es">

    <%- include("../partials/head", { title: "Crear Producto" }) %>

    <body>

        <%- include("../partials/header") %>

        <main class="form-container">

            <div class="create">

                <h1>Crear Producto</h1>

                <form action="/products/create" method="POST" enctype="multipart/form-data">

                    <div class="form-group">
                        <label>Nombre:</label>
                        <input type="text" name="nombre" value="<%= oldData ? oldData.nombre : '' %>" required>
                        <% if (errors && errors.nombre) { %>
                            <p class="error"><%= errors.nombre.msg %></p>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label>Descripción:</label>
                        <textarea name="descripcion" required><%= oldData ? oldData.descripcion : '' %></textarea>
                        <% if (errors && errors.descripcion) { %>
                            <p class="error"><%= errors.descripcion.msg %></p>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label>Imagen:</label>
                        <input type="file" name="imagen">
                        <% if (errors && errors.imagen) { %>
                            <p class="error"><%= errors.imagen.msg %></p>
                        <% } %>
                    </div>

                    <div class="form-row">

                        <div class="form-group">
                            <label>Categoría:</label>
                            <select name="categoria" required>
                                <% categorias.forEach(cat => { %>
                                    <option value="<%= cat.id_categorias %>">
                                        <%= cat.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Marca:</label>
                            <select name="brand" required>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand.id_brands %>">
                                        <%= brand.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Precio:</label>
                            <input type="number" name="precio" value="<%= oldData ? oldData.precio : '' %>" required>
                        </div>

                    </div>

                    <div class="form-actions">
                        <button type="submit">Crear Producto</button>

                        <a href="/products" class="cancel-btn">
                            Cancelar
                        </a>
                    </div>

                </form>

            </div>

        </main>

        <%- include("../partials/footer") %>

    </body>
</html>