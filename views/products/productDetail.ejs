<!DOCTYPE html>
<html lang="en">

<%- include("../partials/head", { title: "Detalles del Producto" }) %>

<body>

    <!-- HEADER -->
    <%- include("../partials/header") %>

    <!-- MAIN -->
    <main class="container product-detail">

        <!-- Imagen / Preview -->
        <div class="product-image">
            <div class="image-placeholder">
                <img src="/images/<%= producto.imagen %>" alt="<%= producto.nombre %>">
            </div>
        </div>

        <!-- Información -->
        <div class="product-info">
            <h1><%= producto.nombre %></h1>

            <div class="product-detail">

                <p><strong>Descripción:</strong> <%= producto.descripcion %></p>

                <p><strong>Categoría:</strong> <%= producto.id_categorias %></p>

                <h3>$<%= producto.precio %></h3>

                <a href="/products">Volver al listado</a>

            </div>
        </div>

    </main>

    <!-- Productos relacionados -->
    <section class="container related-products">

        <h2>Productos relacionados</h2>

        <div class="products">

            <% relacionados.forEach(producto => { %>

                <div class="product-card">

                    <h3><%= producto.nombre %></h3>

                    <p class="price">$<%= producto.precio %></p>

                    <a href="/products/<%= producto.id_productos %>" class="btn-secondary">
                        Ver detalle
                    </a>

                </div>

            <% }) %>

        </div>

    </section>

    <!-- FOOTER -->
    <%- include("../partials/footer") %>

</body>
</html>