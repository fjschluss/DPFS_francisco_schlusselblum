<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuBo</title>
    <link rel="stylesheet" href="/stylesheets/main.css">
</head>

<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar container">

            <div class="logo">
                <a href="/">
                    <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
                </a>
            </div>

            <ul class="menu">
                <li><a href="/">Inicio</a></li>
                <li><a href="#">Comprar</a></li>
                <li><a href="#">Sobre Mi</a></li>
            </ul>

            <div class="nav-actions">
                <a href="/users/login">Login</a>
                <a href="/users/register">Registrarse</a>
                <a href="/cart" class="cart-icon">
                    <img src="/images/Carrito.png" alt="Carrito">
                </a>
            </div>
                
        </nav>
    </header>

    <!-- MAIN -->
    <main class="container product-detail">

        <!-- Imagen / Preview -->
        <div class="product-image">
            <div class="image-placeholder">
                Imagen del producto
            </div>
        </div>

        <!-- Información -->
        <div class="product-info">
            <h1>Tech Pack Camisa Oversize</h1>
            <p class="price">$20 USD</p>

            <p class="description">
                Plantilla profesional editable para producción de camisa oversize.
                Incluye ficha técnica completa, especificaciones y medidas.
            </p>

            <button class="btn-primary">Agregar al carrito</button>

            <div class="product-details-extra">
                <h3>Incluye:</h3>
                <ul>
                    <li>Ficha técnica editable</li>
                    <li>Tabla de medidas</li>
                    <li>Guía de producción</li>
                </ul>
            </div>
        </div>

    </main>

    <!-- Productos relacionados -->
    <section class="container related-products">

        <h2>Productos relacionados</h2>

        <div class="products">
            <div class="card">
                <h3>Molde Pantalón Sastrero</h3>
                <p class="price">$25 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Molde Blazer Clásico</h3>
                <p class="price">$30 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Ficha Técnica Vestido Midi</h3>
                <p class="price">$18 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>
        </div>

    </section>

    <!-- FOOTER -->
    <footer>
        <div class="container footer-content">

            <div class="footer-brand">
                <img src="/images/logo.png" alt="LuBo - Ludmila Borrelli">
            </div>

            <div class="footer-links">
                <a href="#">Política de Privacidad</a>
                <a href="#">Términos y Condiciones</a>
                <a href="#">Contacto</a>
            </div>

            <div class="footer-copy">
                <p>© 2026 LuBo — Ludmila Borrelli</p>
            </div>
        </div>
    </footer>

</body>
</html>