<!DOCTYPE html>
<html lang="en">

<%- include("../partials/head", { title: "Detalles del Producto" }) %>

<body>

    <!-- HEADER -->
    <%- include("../partials/header") %>

    <!-- MAIN -->
    <main class="container product-detail">

        <!-- Imagen / Preview -->
        <div class="product-image">
            <div class="image-placeholder">
                Imagen del producto
            </div>
        </div>

        <!-- Información -->
        <div class="product-info">
            <h1><%= product.name %></h1>
            <p><%= product.description %></p>
            <p><strong>Precio: $<%= product.price %></strong></p>

            <a href="/products">Volver al listado</a>

            <button class="btn-primary">Agregar al carrito</button>

            <div class="product-details-extra">
                <h3>Incluye:</h3>
                <ul>
                    <li>Ficha técnica editable</li>
                    <li>Tabla de medidas</li>
                    <li>Guía de producción</li>
                </ul>
            </div>
        </div>

    </main>

    <!-- Productos relacionados -->
    <section class="container related-products">

        <h2>Productos relacionados</h2>

        <div class="products">
            <div class="card">
                <h3>Molde Pantalón Sastrero</h3>
                <p class="price">$25 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Molde Blazer Clásico</h3>
                <p class="price">$30 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>

            <div class="card">
                <h3>Ficha Técnica Vestido Midi</h3>
                <p class="price">$18 USD</p>
                <a href="/products/productDetail" class="btn-secondary">Ver detalle</a>
            </div>
        </div>

    </section>

    <!-- FOOTER -->
    <%- include("../partials/footer") %>

</body>
</html>